name: CI - Linux

on:
  push:
    branches: [ main ]
  pull_request:
    branches: [ main ]

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Install system dependencies
        run: |
          sudo apt-get update
          # Added libxcb-cursor0 for Qt 6.5 xcb engine and xvfb for running headless GUI tests
          sudo apt-get install -y build-essential cmake ninja-build pkg-config perl curl libxkbcommon-dev libgl1-mesa-dev libxcb-cursor0 xvfb

      - name: Install Qt 6.5 (jurplel/install-qt-action)
        uses: jurplel/install-qt-action@v3
        with:
          version: '6.5.3'
          host: 'linux'
          target: 'desktop'

      # --- OPTIMIZATION: CACHE OPENSSL 3.4.1 TO SPEED UP SUBSEQUENT RUNS ---
      - name: Cache OpenSSL 3.4.1 Build
        id: cache-openssl
        uses: actions/cache@v4
        with:
          path: /home/runner/openssl-3.4.1
          key: ${{ runner.os }}-openssl-3.4.1

      - name: Install OpenSSL 3.4.1 from source (Run only on Cache Miss)
        if: steps.cache-openssl.outputs.cache-hit != 'true'
        run: |
          set -euo pipefail
          OPENSSL_VERSION=3.4.1
          OPENSSL_PREFIX="$HOME/openssl-$OPENSSL_VERSION"
          curl -LO "https://www.openssl.org/source/openssl-$OPENSSL_VERSION.tar.gz"
          tar -xzf "openssl-$OPENSSL_VERSION.tar.gz"
          cd "openssl-$OPENSSL_VERSION"
          ./Configure linux-x86_64 --prefix="$OPENSSL_PREFIX" --openssldir="$OPENSSL_PREFIX/ssl" shared no-tests
          make -j"$(nproc)"
          make install_sw

      # --- GLOBAL RUNTIME REGISTRATION ---
      - name: Export OpenSSL Environment Variables
        run: |
          OPENSSL_PREFIX="/home/runner/openssl-3.4.1"
          echo "OPENSSL_PREFIX=$OPENSSL_PREFIX" >> "$GITHUB_ENV"
          echo "OPENSSL_ROOT_DIR=$OPENSSL_PREFIX" >> "$GITHUB_ENV"
          echo "OPENSSL_MODULES=$OPENSSL_PREFIX/lib64/ossl-modules" >> "$GITHUB_ENV"
          echo "LD_LIBRARY_PATH=$OPENSSL_PREFIX/lib64:$OPENSSL_PREFIX/lib:${LD_LIBRARY_PATH:-}" >> "$GITHUB_ENV"
          echo "$OPENSSL_PREFIX/bin" >> "$GITHUB_PATH"

      - name: Configure
        run: |
          QT_PREFIX=$(dirname "$(dirname "$(which qmake)" )") || true
          mkdir -p build
          cd build
          cmake -S .. -B . -G Ninja -DCMAKE_BUILD_TYPE=Release -DCMAKE_PREFIX_PATH="${QT_PREFIX}/lib/cmake/Qt6" -DOPENSSL_ROOT_DIR="$OPENSSL_ROOT_DIR"

      - name: Build
        run: |
          cd build
          cmake --build . --config Release

      # --- DIAGNOSTIC STEP (FIXED: USING LIB64 RUNTIME DEPENDENCIES) ---
      - name: OpenSSL Diagnostics
        env:
          LD_LIBRARY_PATH: /home/runner/openssl-3.4.1/lib64:/home/runner/openssl-3.4.1/lib
        run: |
            /home/runner/openssl-3.4.1/bin/openssl version
            echo "=== Providers ==="
            /home/runner/openssl-3.4.1/bin/openssl list -providers
            echo "=== KDFs ==="
            /home/runner/openssl-3.4.1/bin/openssl list -kdf-algorithms

      - name: Run tests
        env:
          LD_LIBRARY_PATH: /home/runner/openssl-3.4.1/lib64:/home/runner/openssl-3.4.1/lib
        run: |
          cd build
          xvfb-run ctest -j 2 --output-on-failure